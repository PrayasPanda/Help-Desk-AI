# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg2://quickdesk:quickdesk@localhost:5432/quickdesk

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MIN=480

# LLM — get a free key at https://console.groq.com
# Leave empty to run with a deterministic mock LLM (documented in README)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS
FRONTEND_ORIGIN=http://localhost:5173
